rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation helpers
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() <= 6;
    }

    function isValidProgress(data) {
      return data.userId == request.auth.uid &&
             data.keys().hasAll(['userId']) &&
             data.keys().size() <= 5;
    }

    function isValidSession(data) {
      return data.userId == request.auth.uid &&
             data.polylines is list &&
             data.keys().hasAll(['userId', 'polylines']) &&
             data.keys().size() <= 10;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'role']);
    }

    match /progress/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProgress(incoming());
      allow update: if isOwner(userId) && isValidProgress(incoming());
    }

    match /sessions/{sessionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSession(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidSession(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
